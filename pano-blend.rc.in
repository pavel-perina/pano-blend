// Windows VERSIONINFO resource for pano-blend.
// Generated at build time from pano-blend.rc.in by cmake/GenerateVersion.cmake.
// Both the numeric fields and the human-readable string come from
// `git describe` — the tag is the single source of the version.
#include <winver.h>

VS_VERSION_INFO VERSIONINFO
    FILEVERSION    @PANOBLEND_VERSION_MAJOR@,@PANOBLEND_VERSION_MINOR@,@PANOBLEND_VERSION_PATCH@,0
    PRODUCTVERSION @PANOBLEND_VERSION_MAJOR@,@PANOBLEND_VERSION_MINOR@,@PANOBLEND_VERSION_PATCH@,0
    FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
    FILEFLAGS      0
    FILEOS         VOS__WINDOWS32
    FILETYPE       VFT_APP
    FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"  // U.S. English, Unicode
        BEGIN
            VALUE "CompanyName",      "Pavel Perina"
            VALUE "FileDescription",  "Panoramic image blender - graph-cut seams + multi-band blend"
            VALUE "FileVersion",      "@PANOBLEND_VERSION@"
            VALUE "InternalName",     "pano-blend"
            VALUE "LegalCopyright",   "MIT License. Copyright (c) 2026 Pavel Perina"
            VALUE "OriginalFilename", "pano-blend.exe"
            VALUE "ProductName",      "pano-blend"
            VALUE "ProductVersion",   "@PANOBLEND_VERSION@"
            VALUE "Comments",         "https://github.com/pavel-perina/pano-blend"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200  // U.S. English, Unicode (0x4b0)
    END
END
